<!-- =========================================================
     HERO
     ========================================================= -->
<section class="hero" id="home">
  <div class="container hero-inner">

    <div class="hero-content">
      <div class="hero-badge">&#11088; Brookline&rsquo;s Trusted General Contractor</div>
      <h1>Greater Boston Renovations, Done Right</h1>
      <div class="hero-mobile-cta">
        <a href="tel:+16175550100" class="btn btn-accent btn-lg">Call Now: (617) 555-0100</a>
      </div>
      <ul class="hero-checks">
        <li><span class="check">&#10003;</span> Free estimates &mdash; no obligation</li>
        <li><span class="check">&#10003;</span> On time, on budget &mdash; guaranteed</li>
        <li><span class="check">&#10003;</span> Quality craftsmanship, every time</li>
      </ul>
      <p class="hero-subtext">Licensed &amp; insured general contractor serving Brookline, Boston, Newton, Cambridge &amp; surrounding communities.</p>
    </div>

    <div class="hero-form-card">
      <div class="form-card-header">
        <h2>Tell us about your project</h2>
        <p>We&rsquo;ll reach out to gather more info before a site visit.</p>
      </div>
      <form class="quote-form" id="hero-quote-form" name="hero-quote" data-netlify="true" novalidate>
        <input type="hidden" name="form-name" value="hero-quote">

        <div class="form-step-indicator">
          <span class="step-pip active"></span>
          <span class="step-pip"></span>
        </div>

        <!-- Step 1: Contact info -->
        <div class="form-step" id="hero-step-1">
          <div class="form-group">
            <label for="hero-name">Your Name <span class="req">*</span></label>
            <input type="text" id="hero-name" name="name" placeholder="John Smith" required>
          </div>
          <div class="form-group">
            <label for="hero-email">Email <span class="req">*</span></label>
            <input type="email" id="hero-email" name="email" placeholder="your@email.com" required>
          </div>
          <button type="button" class="btn btn-accent btn-full" id="hero-next-btn">
            Next: Project Details &rarr;
          </button>
        </div>

        <!-- Step 2: Project info -->
        <div class="form-step" id="hero-step-2" hidden>
          <div class="form-group">
            <label for="hero-service">Project Type <span class="req">*</span></label>
            <select id="hero-service" name="service" required>
              <option value="">Select a project type&hellip;</option>
              <option>Kitchen Remodeling</option>
              <option>Bathroom Remodeling</option>
              <option>Home Addition</option>
              <option>Basement Finishing</option>
              <option>Full Home Renovation</option>
              <option>Flooring Installation</option>
              <option>Carpentry &amp; Custom Millwork</option>
              <option>Deck &amp; Outdoor Living</option>
              <option>Window &amp; Door Replacement</option>
              <option>Interior &amp; Exterior Painting</option>
              <option>Other</option>
            </select>
          </div>
          <div class="form-group">
            <label for="hero-message">Brief Description</label>
            <textarea id="hero-message" name="message" rows="5" placeholder="Tell us a bit about what you need&hellip;"></textarea>
          </div>
          <button type="submit" class="btn btn-accent btn-full">
            Request My Free Quote &rarr;
          </button>
          <div class="form-step-back">
            <button type="button" id="hero-back-btn">&larr; Back</button>
          </div>
          <p class="form-disclaimer">No spam, we promise.</p>
        </div>

      </form>
      <div class="form-success" id="hero-form-success" hidden>
        <div class="success-icon">&#10003;</div>
        <h3>Request Received!</h3>
        <p>Thanks! We&rsquo;ll be in touch soon.</p>
      </div>
    </div>

  </div>
</section>


